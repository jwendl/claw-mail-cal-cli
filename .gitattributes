# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Explicitly enforce LF for all source and config text files
*.cs text eol=lf
*.csproj text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.sln text eol=lf
*.slnx text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.editorconfig text eol=lf
*.gitattributes text eol=lf
*.gitignore text eol=lf
*.razor text eol=lf

# Binary files - no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
